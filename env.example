# Example environment variables for this project
# Copy this file to `.env` and fill the values for local development.

# Public URL used by the app (change after you have your Vercel URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Production/Postgres/Database connection URL
# Example: postgres://user:password@host:5432/dbname
DATABASE_URL=

# Optional DB provider auth token (if your DB provider uses a token)
DATABASE_AUTH_TOKEN=

# Resend (or other email service) API key used for sending emails
RESEND_API_KEY=

# Default "from" address for invoice emails
# Example: DispoInvoice <invoice@yourdomain.com>
INVOICE_EMAIL_FROM=
